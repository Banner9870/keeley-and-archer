# Copy this file to .env and fill in your values.
# Never commit .env to git.

VITE_GOOGLE_PLACES_API_KEY=
VITE_CHICAGO_DATA_PORTAL_TOKEN=

# Express server base URL — leave empty for local dev (Vite proxy handles /api/* requests).
# Set to your Railway Express service URL at deploy time, e.g. https://chicago-com-server.railway.app
VITE_API_BASE_URL=
